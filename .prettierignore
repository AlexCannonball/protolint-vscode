# Ignore everything by default
*

# Don't ignore directories (so we can look inside them for other files)
!*/

# Don't ignore JavaScript files
!**/*.js
!**/*.cjs
!**/*.mjs

# Don't ignore JSON files
!**/*.json

# Ignore package.json
**/package.json

# Ignore lock files
**/devcontainer-lock.json
**/package-lock.json

# Don't ignore markdown files
!**/*.md

# Don't ignore TypeScript files
!**/*.ts
!**/*.cts
!**/*.mts

# Ignore .vscode-test
.vscode-test/

# Ignore compiled files directory
dist/

# Ignore fixtures directory
fixtures/

# Ignore compiled test directory
test-compiled/

# Ignore the changelog file
CHANGELOG.md
